# Database
DATABASE_URL=postgresql://postgres:CHANGE-ME@localhost:5432/compare

# Admin bootstrap (one-time, ignored after first run)
ADMIN_INITIAL_USERNAME=owner
ADMIN_INITIAL_PASSWORD=CHANGE-ME-AT-FIRST-LOGIN

# Session
SESSION_SECRET=replace-with-64-char-random-hex

# Validator shared token (must match between worker and validator)
VALIDATOR_SHARED_TOKEN=replace-with-secure-random-token

# Validator base URL (worker uses this to call validator)
VALIDATOR_BASE_URL=http://validator:3001

# X (Twitter) API
X_BEARER_TOKEN=

# Telegram MTProto
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Optional public web search engines (Bing RSS works without a key)
BRAVE_SEARCH_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
SERPER_API_KEY=
PUBLIC_SEARCH_MAX_RESULTS=50

# FX rate source (ECB or custom)
FX_RATE_SOURCE=https://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml
