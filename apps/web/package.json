{
  "name": "@compare/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @compare/domain build && pnpm --filter @compare/db build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0 --ignore-pattern .next --ignore-pattern node_modules",
    "test": "vitest run",
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "@compare/db": "workspace:*",
    "@compare/domain": "workspace:*",
    "@node-rs/argon2": "2.0.2",
    "@tailwindcss/postcss": "^4.3.2",
    "drizzle-orm": "0.44.7",
    "lucide-react": "0.524.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4.3.2",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/node": "24.10.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.8.3",
    "vitest": "4.1.10"
  }
}
